import numpy as np

def numpy_dashboard():
    print("=== NumPy Statistics Dashboard (CLI) ===")
    user_input = input("Enter numbers separated by spaces (e.g., 10 20 30 40): ")
    
    try:
        # Convert input string to a numpy array
        data = np.array([float(x) for x in user_input.split()])
        
        if len(data) == 0:
            print("No data entered!")
            return

        # Perform calculations
        stats = {
            "Count": len(data),
            "Minimum": np.min(data),
            "Maximum": np.max(data),
            "Mean": np.mean(data),
            "Median": np.median(data),
            "Std Dev": np.std(data),
            "Variance": np.var(data),
            "Sum": np.sum(data)
        }

        print("\n--- Statistical Summary ---")
        for key, value in stats.items():
            print(f"{key.ljust(15)}: {value:.4f}")
            
    except ValueError:
        print("Error: Please enter only numeric values separated by spaces.")

numpy_dashboard()
